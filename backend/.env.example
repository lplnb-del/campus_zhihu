# ==========================================
# CampusZhihu 环境变量配置示例
# ==========================================
# 使用方法：
# 1. 复制此文件并重命名为 .env
# 2. 填写真实的配置值
# 3. 确保在生产环境中使用强密码和安全的密钥
# ==========================================

# ==========================================
# 数据库配置
# ==========================================
# 数据库连接 URL
DB_URL=jdbc:mysql://localhost:3306/campus_zhihu?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# 数据库用户名
DB_USERNAME=root

# 数据库密码（必填）
DB_PASSWORD=your_secure_database_password_here

# ==========================================
# JWT 配置
# ==========================================
# JWT 密钥（必填，至少32字符）
# 生成方法: openssl rand -base64 32
JWT_SECRET=your_very_secure_jwt_secret_key_at_least_32_characters_long

# ==========================================
# Redis 配置
# ==========================================
# Redis 主机地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码（如果设置了密码）
REDIS_PASSWORD=

# ==========================================
# 邮件配置
# ==========================================
# 邮件服务器主机
MAIL_HOST=smtp.qq.com

# 邮件服务器端口
MAIL_PORT=587

# 邮件服务器用户名
MAIL_USERNAME=your_email@qq.com

# 邮件服务器密码/授权码
MAIL_PASSWORD=your_email_authorization_code

# ==========================================
# MinIO 对象存储配置
# ==========================================
# MinIO 访问密钥
MINIO_ACCESS_KEY=minioadmin

# MinIO 密钥（必填）
MINIO_SECRET_KEY=your_minio_secret_key_here

# ==========================================
# Druid 监控配置
# ==========================================
# Druid 监控后台用户名
DRUID_USERNAME=admin

# Druid 监控后台密码
DRUID_PASSWORD=admin123456

# ==========================================
# 应用配置
# ==========================================
# 应用 URL（用于生成邮件中的链接）
APP_URL=http://localhost:3000

# ==========================================
# 安全提示
# ==========================================
# 1. 永远不要将 .env 文件提交到版本控制系统
# 2. 生产环境中的密码和密钥必须足够复杂
# 3. 定期更换密钥和密码
# 4. 使用不同的密码用于不同环境
# 5. 限制数据库用户的权限，遵循最小权限原则
